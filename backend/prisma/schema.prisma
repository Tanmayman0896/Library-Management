generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("STUDENT")
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Desk {
  id       String    @id @default(uuid())
  label    String    @unique  // e.g. "LW-22", "A-01"
  wing     String             // "LEFT" | "RIGHT"
  type     String    @default("PC") // PC | STUDY | CUBICLE
  row      Int       @default(0)
  col      Int       @default(0)
  status   String    @default("FREE")
  sessions Session[]
}

model Session {
  id            String    @id @default(uuid())
  userId        String
  deskId        String
  status        String    @default("ACTIVE")
  startTime     DateTime  @default(now())
  awayStartTime DateTime?
  lastPingTime  DateTime  @default(now())
  endTime       DateTime?
  user          User      @relation(fields: [userId], references: [id])
  desk          Desk      @relation(fields: [deskId], references: [id])
}
